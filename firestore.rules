rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "ignaciomartinez21@hotmail.com";
    }

    match /agenda/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{docId} {
      allow read: if resource.data.approved == true || isAdmin();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /suggestions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /registrations/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
  }
}
